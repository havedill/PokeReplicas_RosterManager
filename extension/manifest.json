{
  "manifest_version": 3,
  "name": "Pokebox for PokeReplicas",
  "version": "1.7",
  "description": "Track your Pokémon Champions box and sort PokeReplicas teams by roster match.",
  "permissions": ["storage", "alarms", "windows"],
  "host_permissions": ["*://pokemonchampionsreplicateams.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Pokebox"
  },
  "content_scripts": [
    {
      "matches": ["*://pokemonchampionsreplicateams.com/*"],
      "css": ["content.css"],
      "js": ["roster-utils.js", "content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
